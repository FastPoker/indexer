{
  "name": "fastpoker-indexer-public",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone FastPoker protocol read indexer. Subscribes to L1 program events, persists chain-derived data to MongoDB, and serves read APIs.",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "backfill": "tsx scripts/backfill.ts",
    "backfill:token-mints": "tsx scripts/backfill-token-mints-once.ts",
    "recover:jackpots": "tsx scripts/recover-jackpots.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.1",
    "@solana/web3.js": "^1.95.0",
    "@types/ws": "^8.18.1",
    "bs58": "^5.0.0",
    "laserstream-core-proto-js": "^9.0.2",
    "mongodb": "^6.8.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  }
}
