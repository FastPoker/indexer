# fastpoker indexer-standalone source config

# MongoDB for chain-derived indexed data.
MONGO_URI=mongodb://localhost:27017
MONGO_DB=fastpoker_indexer

# Solana RPC.
# Required. Do not use the public/free Solana RPC for this indexer; historical
# backfill and live cache reseeds need a paid/dedicated endpoint with enough
# rate limit and WebSocket support.
#
# A free Helius key is acceptable only for local smoke tests. It has low RPC
# limits and standard LaserStream WebSocket support, but not the mainnet
# LaserStream gRPC stream this indexer adapter uses through STREAM_ENDPOINT.
RPC_URL=

# Optional if your provider's WS endpoint is just RPC_URL with https -> wss.
# Set it explicitly when your provider gives a separate WebSocket URL.
RPC_WS_URL=

# Required for production FULL/live indexing. The bundled stream adapter is
# LaserStream/Geyser-compatible. Leave blank only for local smoke tests; caches
# will rely on slower RPC reseeds/polling and can lag.
STREAM_PROVIDER=laserstream
STREAM_ENDPOINT=
STREAM_API_KEY=
# Backward-compatible aliases also accepted:
# LASERSTREAM_ENDPOINT=
# LASERSTREAM_API_KEY=
# HELIUS_API_KEY=

# Live mainnet FastPoker program by default.
PROGRAM_ID=PokerXYdXL2SKNnfGbv1WE7vJHipTpNsfZbZeVvoJLn

# HTTP + WebSocket port.
INDEXER_PORT=3001

# Historical backfill controls.
BACKFILL_LOOKBACK_HOURS=720
BACKFILL_THROTTLE_MS=100

# Optional one-shot startup recovery sweep. 0 = off.
RECOVER_LOOKBACK_HOURS=0
